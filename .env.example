# ══════════════════════════════════════════
# ⚙️ VISA BOT — Configuration
# ══════════════════════════════════════════
# 1. Rename this file to .env
# 2. Fill in your actual credentials
# 3. Never share your .env file! ❌
# ══════════════════════════════════════════

# 👤 Personal Info
FIRST_NAME=XXX
LAST_NAME=XXX

# 📧 Gmail — IMAP must be enabled + App Password required
GMAIL=XXX@gmail.com
GMAIL_PASS=xxxx xxxx xxxx xxxx

# 🔑 TLS Password (choose your own — must NOT be your Gmail password)
TLS_PASSWORD=XXX

# 🏙️ City: marrakech / casablanca / rabat / tanger / fes / agadir
CITY=marrakech

# 🌍 Country: fr / be / de / it / nl / es / ca
COUNTRY=fr

# ⏱️ Check interval in seconds (10 recommended)
INTERVAL=10

# 📱 Twilio — WhatsApp
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WA_PHONE=+212XXXXXXXXX

# 💬 Telegram
TG_TOKEN=XXXXXXXXXX:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TG_CHAT_ID=XXXXXXXXX
